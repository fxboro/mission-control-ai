rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global function to assert user identity
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // A helper to assert ownership for created data
    function isCreateValid() {
      return request.resource.data.userId == request.auth.uid;
    }

    // Users collection
    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }

    // Goals collection
    match /goals/{goalId} {
      allow read, update, delete: if isOwner(resource.data.userId);
      allow create: if isCreateValid();
    }

    // Projects collection
    match /projects/{projectId} {
      allow read, update, delete: if isOwner(resource.data.userId);
      allow create: if isCreateValid();
    }

    // Tasks collection
    match /tasks/{taskId} {
      allow read, update, delete: if isOwner(resource.data.userId);
      allow create: if isCreateValid();
    }

    // Decisions collection
    match /decisions/{decisionId} {
      allow read, update, delete: if isOwner(resource.data.userId);
      allow create: if isCreateValid();
    }

    // Playbooks collection
    match /playbooks/{playbookId} {
      allow read, update, delete: if isOwner(resource.data.userId);
      allow create: if isCreateValid();
    }

    // Leads collection
    match /leads/{leadId} {
      allow read, update, delete: if isOwner(resource.data.userId);
      allow create: if isCreateValid();
    }

    // Proposals collection
    match /proposals/{proposalId} {
      allow read, update, delete: if isOwner(resource.data.userId);
      allow create: if isCreateValid();
    }

    // Agent Runs collection
    match /agent_runs/{runId} {
      allow read, update, delete: if isOwner(resource.data.userId);
      allow create: if isCreateValid();
    }

    // Memory collection
    match /memory/{memoryId} {
      allow read, update, delete: if isOwner(resource.data.userId);
      allow create: if isCreateValid();
    }
  }
}
