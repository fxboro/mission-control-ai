rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    // Applies strict ownership rules on writes
    function enforceOwnershipWrite() {
      return isOwner(request.resource.data.userId) 
        && request.resource.data.createdAt is number 
        && request.resource.data.updatedAt is number;
    }
    
    // For updates, the record must already belong to the user,
    // AND they cannot hijack the record by changing the userId.
    function enforceOwnershipUpdate() {
      return isOwner(resource.data.userId) 
        && isOwner(request.resource.data.userId)
        && request.resource.data.updatedAt is number;
    }

    // ─────────────────────────────────────────────────────────────
    // 1. Users Profile
    // Lock reading and writing explicitly to auth.uid
    // ─────────────────────────────────────────────────────────────
    match /users/{uid} {
      allow read: if isAuthenticated() && request.auth.uid == uid;
      allow create: if isAuthenticated() && request.auth.uid == uid 
                   && request.resource.data.uid == uid;
      allow update: if isAuthenticated() && request.auth.uid == uid 
                   && request.resource.data.uid == uid;
      allow delete: if false; // Only allow account deletion via Cloud Functions or Server SDK
    }

    // ─────────────────────────────────────────────────────────────
    // 2. Base Entity Matches
    // Collections: goals, projects, tasks, decisions, playbooks, 
    // learning_items, leads, proposals, agent_runs, memories
    // ─────────────────────────────────────────────────────────────
    match /{collection}/{id} {
      // Whitelist domains to avoid accidental misconfigurations globally
      allow read, delete: if collection in ['goals', 'projects', 'tasks', 'decisions', 'playbooks', 'learning_items', 'leads', 'proposals', 'agent_runs', 'memories']
        && isOwner(resource.data.userId);
        
      allow create: if collection in ['goals', 'projects', 'tasks', 'decisions', 'playbooks', 'learning_items', 'leads', 'proposals', 'agent_runs', 'memories']
        && enforceOwnershipWrite();
        
      allow update: if collection in ['goals', 'projects', 'tasks', 'decisions', 'playbooks', 'learning_items', 'leads', 'proposals', 'agent_runs', 'memories']
        && enforceOwnershipUpdate();
    }
  }
}
